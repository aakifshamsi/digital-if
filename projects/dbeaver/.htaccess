# DigitalHands.in — Apache config for shared Linux hosting
# Place this file in your public_html/spa-builder/ directory

Options -Indexes
ServerSignature Off

# PHP settings (mod_php only — FPM hosts: see api/config.php ini_set calls)
<IfModule mod_php.c>
    php_value session.cookie_httponly  On
    php_value session.use_strict_mode  On
    php_value session.gc_maxlifetime   3600
    php_value upload_max_filesize      10M
    php_value post_max_size            12M
</IfModule>
<IfModule mod_php7.c>
    php_value session.cookie_httponly  On
    php_value session.use_strict_mode  On
    php_value session.gc_maxlifetime   3600
</IfModule>
<IfModule mod_php8.c>
    php_value session.cookie_httponly  On
    php_value session.use_strict_mode  On
    php_value session.gc_maxlifetime   3600
</IfModule>

# Protect sensitive files
<FilesMatch "(^\.env|users\.json|config\.php|composer\.(json|lock)|package(-lock)?\.json)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule mod_access_compat.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Rewrite rules
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirect direct access to api/ directory listing
    RewriteRule ^api/?$  - [F,L]

    # Remove .html extension (optional, for cleaner URLs)
    # RewriteCond %{REQUEST_FILENAME} !-f
    # RewriteCond %{REQUEST_FILENAME}.html -f
    # RewriteRule ^(.+)$ $1.html [L]
</IfModule>

# GZIP compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json
</IfModule>

# Browser caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css            "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg          "access plus 6 months"
    ExpiresByType image/png           "access plus 6 months"
    ExpiresByType image/webp          "access plus 6 months"
    ExpiresByType image/svg+xml       "access plus 1 month"
    ExpiresByType font/woff2          "access plus 1 year"
    ExpiresByType text/html           "access plus 0 seconds"
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # XSS-Protection disabled per OWASP — use Content-Security-Policy instead
    Header always set X-XSS-Protection "0"
</IfModule>

# Force HTTPS (uncomment once SSL is active)
# <IfModule mod_rewrite.c>
#     RewriteCond %{HTTPS} off
#     RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>
